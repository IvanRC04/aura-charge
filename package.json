{
  "name": "aura-charge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "sync-env": "node scripts/sync-env.mjs",
    "dev": "pnpm sync-env && turbo run dev --parallel",
    "dev:web": "pnpm sync-env && turbo run dev --filter=web",
    "dev:crm": "pnpm sync-env && turbo run dev --filter=crm",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:push": "pnpm sync-env && pnpm --filter @aura/db exec drizzle-kit push",
    "db:generate": "pnpm sync-env && pnpm --filter @aura/db generate",
    "db:migrate": "pnpm sync-env && pnpm --filter @aura/db migrate",
    "db:seed": "pnpm sync-env && pnpm --filter @aura/db seed",
    "db:studio": "pnpm sync-env && pnpm --filter @aura/db studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2"
  },
  "engines": {
    "node": ">=20"
  }
}
