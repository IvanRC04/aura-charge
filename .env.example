# Neon Postgres (provisioned via Vercel Marketplace -> Neon)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Upstash Redis (provisioned via Vercel Marketplace -> Upstash)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."

# Groq (https://console.groq.com - free tier)
GROQ_API_KEY="gsk_..."

# Random secret shared between web + crm (any string >= 16 chars)
INTERNAL_SECRET="changeme-please-32-chars-minimum"

# Public URLs of the two deployments (set per-project on Vercel)
NEXT_PUBLIC_WEB_URL="https://aura-charge.vercel.app"
NEXT_PUBLIC_CRM_URL="https://aura-charge-crm.vercel.app"
